    "project_path": ".mufreze/exp/",
    "global_path": "~/.mufreze/experiences/",
    "auto_save": true,
    "promote_threshold": 3
  },
  "verify": {
    "run_syntax_check": true,
    "run_type_check": true,
    "fail_on_error": true
  }
}
