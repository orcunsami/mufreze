{
  "mode": "delegation",
  "version": "1.1.0",
  "workers": {
    "coder": "kimi",
    "reviewer": "claude-sonnet-4-6",
    "tester": "codex",
    "architect": "claude-opus-4-6"
  },
  "retry": {
    "max_attempts": 5,
    "timeout_seconds": 180,
    "escalate_chain": ["codex", "claude-sonnet-4-6", "claude-opus-4-6"]
